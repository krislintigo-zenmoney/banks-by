{
  "name": "@krislintigo-zenmoney/banks-by",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm banks:build && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint",
    "format:check": "prettier \"**/*.{ts,js,vue}\" --check",
    "format:fix": "prettier \"**/*.{ts,js,vue}\" --write",
    "banks:build": "node scripts/build-banks.mjs",
    "banks:watch": "node scripts/build-banks.mjs && node scripts/watch-banks.mjs"
  },
  "prettier": "@krislintigo/prettier-config",
  "dependencies": {
    "nuxt": "^4.4.8"
  },
  "devDependencies": {
    "@krislintigo/eslint-config": "^2.1.0",
    "@krislintigo/eslint-config-vue": "^1.1.0",
    "@krislintigo/prettier-config": "^1.0.0",
    "@krislintigo/tsconfig": "^1.4.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "chokidar": "^5.0.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.6"
  }
}
